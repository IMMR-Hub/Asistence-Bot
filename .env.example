# Application
APP_ENV=development
APP_PORT=8000
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://salesbot:salesbot_secret@db:5432/salesbot_db

# Redis
REDIS_URL=redis://redis:6379/0

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CLASSIFICATION_MODEL=qwen2.5:7b-instruct
OLLAMA_RESPONSE_MODEL=qwen2.5:14b-instruct
OLLAMA_FALLBACK_MODEL=llama3.1:8b-instruct
OLLAMA_TIMEOUT=60

# OpenAI Fallback (Optional)
OPENAI_COMPATIBLE_API_BASE_OPTIONAL=
OPENAI_COMPATIBLE_API_KEY_OPTIONAL=
OPENAI_FALLBACK_ENABLED=false

# WhatsApp
WHATSAPP_PROVIDER=meta
WHATSAPP_VERIFY_TOKEN=my-unique-verify-token-change-this
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Twilio (Optional)
TWILIO_ACCOUNT_SID_OPTIONAL=
TWILIO_AUTH_TOKEN_OPTIONAL=
TWILIO_WHATSAPP_NUMBER_OPTIONAL=

# Gmail (Optional)
GMAIL_CLIENT_ID_OPTIONAL=
GMAIL_CLIENT_SECRET_OPTIONAL=
GMAIL_REFRESH_TOKEN_OPTIONAL=

# SMTP (Optional)
SMTP_HOST_OPTIONAL=
SMTP_PORT_OPTIONAL=587
SMTP_USERNAME_OPTIONAL=
SMTP_PASSWORD_OPTIONAL=
SMTP_USE_TLS=true

# App Settings
DEFAULT_TIMEZONE=UTC
RQ_QUEUE_NAME=default

# Security
API_SECRET_KEY=your-super-secret-api-key-change-this-in-production
WEBHOOK_SIGNATURE_VERIFY=true
