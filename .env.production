# ════════════════════════════════════════════════════════════════════════════
# APPLICATION SETTINGS
# ════════════════════════════════════════════════════════════════════════════
APP_ENV=production
APP_PORT=8000
DEBUG=false

# ════════════════════════════════════════════════════════════════════════════
# DATABASE (PostgreSQL RDS or managed database)
# ════════════════════════════════════════════════════════════════════════════
# REEMPLAZA CON TU DATABASE URL REAL:
# Ejemplo AWS RDS: postgresql+asyncpg://admin:SecurePass@sales-db.c9akciq32.us-east-1.rds.amazonaws.com:5432/salesbot_prod
DATABASE_URL=postgresql+asyncpg://salesbot_user:CHANGE_ME_STRONG_PASSWORD@db.example.com:5432/salesbot_prod

# ════════════════════════════════════════════════════════════════════════════
# REDIS (Para cache y queue)
# ════════════════════════════════════════════════════════════════════════════
# Ejemplo: redis://default:SecurePass@redis.c9akciq32.ng.0001.use1.cache.amazonaws.com:6379/0
REDIS_URL=redis://CHANGE_ME_HOST:6379/0

# ════════════════════════════════════════════════════════════════════════════
# LLM SETTINGS - GROQ (Rápido, barato, en producción)
# ════════════════════════════════════════════════════════════════════════════
# 1. Crear API key en https://console.groq.com/keys
# 2. Copy aquí:
LLM_PROVIDER=groq
LLM_API_KEY=gsk_YOUR_REAL_API_KEY_HERE
LLM_API_BASE=https://api.groq.com/openai/v1
LLM_CLASSIFY_MODEL=llama-3.1-8b-instant
LLM_RESPONSE_MODEL=llama-3.1-70b-versatile
# ⭐ CRÍTICO: Timeouts que funcionan con Twilio
LLM_TIMEOUT=8
LLM_TIMEOUT_FALLBACK=16

# ════════════════════════════════════════════════════════════════════════════
# FALLBACK LLM - OLLAMA (Local, para si Groq falla)
# ════════════════════════════════════════════════════════════════════════════
# En producción, mantener Ollama en standby en otra máquina
LLM_FALLBACK_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama-standby:11434
OLLAMA_FALLBACK_MODEL=qwen2.5:7b-instruct

# ════════════════════════════════════════════════════════════════════════════
# WHATSAPP - TWILIO (Con credenciales REALES de cliente)
# ════════════════════════════════════════════════════════════════════════════
# 1. Ve a https://console.twilio.com (login con tu account)
# 2. Copia Account SID desde dashboard:
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID_OPTIONAL=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 3. Copia Auth Token:
TWILIO_AUTH_TOKEN_OPTIONAL=your_auth_token_here
# 4. Número Twilio asignado para WhatsApp (con formato +1234567890):
TWILIO_WHATSAPP_NUMBER_OPTIONAL=+1234567890

# ════════════════════════════════════════════════════════════════════════════
# OPTIONAL: Meta WhatsApp Business (si cliente tiene su propia línea)
# ════════════════════════════════════════════════════════════════════════════
WHATSAPP_PROVIDER=twilio
WHATSAPP_VERIFY_TOKEN=some-random-token-for-webhook-verification
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ════════════════════════════════════════════════════════════════════════════
# OPTIONAL: Email (si quieres mandar reportes)
# ════════════════════════════════════════════════════════════════════════════
SMTP_HOST_OPTIONAL=
SMTP_PORT_OPTIONAL=587
SMTP_USERNAME_OPTIONAL=
SMTP_PASSWORD_OPTIONAL=
SMTP_USE_TLS=true

# ════════════════════════════════════════════════════════════════════════════
# APP SPECIFIC
# ════════════════════════════════════════════════════════════════════════════
DEFAULT_TIMEZONE=America/Asuncion
RQ_QUEUE_NAME=default
# REEMPLAZA CON TU API SECRET REAL (256 caracteres random):
API_SECRET_KEY=your-super-secret-production-key-change-this-to-something-secure-and-random
WEBHOOK_SIGNATURE_VERIFY=true
